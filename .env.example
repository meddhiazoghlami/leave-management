# Copy to .env and adjust: `cp .env.example .env`
#
# The app loads .env automatically for local `go run` (via godotenv). Docker
# Compose also reads .env for ${VAR} interpolation. Keep values unquoted and
# free of spaces so `make` can `include` this file too.

# ── Application ────────────────────────────────────────────────────────────
# REQUIRED — the app exits if this is unset (no built-in default).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/leave_management?sslmode=disable

# Optional
ADDR=:8080
# Externally-reachable root of the app, used to build the login link in the
# bootstrap credential email.
BASE_URL=http://localhost:8080
# VITE_DEV=true            # serve assets from the Vite dev server (HMR)
# Apply pending DB migrations automatically on `serve`/`seed` startup. Handy for
# local dev so the app "just works" after a schema change; leave unset in prod,
# where the Compose `migrate` service runs migrations as a separate step.
AUTO_MIGRATE=true

# ── Bootstrap accounts (internal/bootstrap) ─────────────────────────────────
# On `serve` startup the app ensures an admin and an HR account exist for these
# emails. On first creation it generates a random password and emails it via
# SMTP below; if an account already exists it is left untouched. Leave an email
# blank to skip bootstrapping that role.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_HR_EMAIL=hr@example.com

# SMTP transport for the credential email. Required only when a bootstrap
# account actually needs creating (an already-provisioned DB needs none of it).
# Startup aborts if a send is needed and these are missing or the send fails.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com

# ── Observability (internal/obs) ────────────────────────────────────────────
# All optional — an empty value disables that exporter, so a plain `go run` with
# no monitoring stack still works. In Docker Compose these are set to the stack's
# service names (see docker-compose.yml); the values here are for running the app
# directly on your machine against `make observability-up`.
SERVICE_NAME=leave-management
# OTLP/HTTP trace collector (Tempo). Empty ⇒ tracing disabled.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Loki base URL for the log-push handler. Empty ⇒ logs go to stdout only.
# LOKI_URL=http://localhost:3100

# ── Docker Compose (Postgres service + host port mappings) ─────────────────
# These feed the compose file. Inside Compose the app talks to the "db" host,
# not localhost, so its DATABASE_URL is built from these — not from the value
# above (which is for running the app directly on your machine).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=leave_management
DB_PORT=5432
APP_PORT=8080

# Observability stack host ports + Grafana login (only used with the
# "observability" compose profile).
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
PROMETHEUS_PORT=9090
LOKI_PORT=3100
TEMPO_PORT=3200
POSTGRES_EXPORTER_PORT=9187
